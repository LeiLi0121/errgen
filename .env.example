# ============================================================
# ERRGen – Environment Variables
# Copy this file to .env and fill in your real values.
# NEVER commit .env to version control.
# ============================================================

# ----- OpenAI -----
# Required. Get your key at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Optional: override default models
OPENAI_MODEL=gpt-4o
OPENAI_FAST_MODEL=gpt-4o-mini
OPENAI_MAX_TOKENS=4096
OPENAI_TEMPERATURE=0.2

# ----- Financial Modeling Prep (FMP) -----
# Required. Free tier at https://financialmodelingprep.com/developer/docs/
# Covers: income statement, balance sheet, cash flow, company profile, news
# Free tier: 250 requests/day
FMP_API_KEY=your_fmp_key_here

# ----- NewsAPI -----
# Required. Free developer tier at https://newsapi.org/
# Free tier: 100 requests/day, no commercial use
# Upgrade to paid for production use
NEWSAPI_KEY=your_newsapi_key_here

# ----- Pipeline Tuning (optional) -----
MAX_REVISION_ITERATIONS=3
MAX_NEWS_ARTICLES=20
MAX_FINANCIAL_PERIODS=4
LLM_RETRY_ATTEMPTS=3
LLM_RETRY_DELAY=5.0

# ----- Storage -----
RUNS_DIR=runs
